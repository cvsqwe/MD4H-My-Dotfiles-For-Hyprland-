{
    "layer": "down",
    "position": "down",
    "margin-top": 10,
    "margin-left": 150,
    "margin-right": 150,
    "height": 40,
    "spacing": 0,
    "reload_style_on_change": true,

    "modules-left": [
        "custom/launcher",
        "hyprland/workspaces",
        "cpu",
        "memory"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "network",
        "hyprland/language",
        "pulseaudio",
        "custom/power"
    ],

    "custom/launcher": {
        "format": "",
        "on-click": "rofi -show drun",
        "tooltip": false
    },

   "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "all-outputs": true,
    "sort-by-number": true,
    "format-icons": {
        "1": "",      // Браузер
        "2": "",      // Кодинг (Helix/Neovim)
        "3": "",      // Терминал
        "4": "󰙯",      // Дискорд / Мессенджеры
        "5": "",      // Музыка
        "default": "" // Пустой воркспейс
    },
    "persistent-workspaces": {
        "*": 5 // Чтобы иконки 1-5 всегда висели в баре
    }
},
    "cpu": {
        "format": "󰻠 {usage}%",
        "interval": 2
    },

    "memory": {
        "format": "󰍛 {percentage}%",
        "interval": 5
    },

    "clock": {
        "format": "{:%H:%M:%S}",
        "format-alt": "󰃭 {:%d.%m.%Y}",
        "interval": 1
    },

    "network": {
        "format-wifi": "",
        "format-ethernet": "󰈀",
        "format-disconnected": "󰖪",
        "tooltip-format": "{essid} {ipaddr}"
    },

    "hyprland/language": {
        "format": " {short}",
        "format-en": "US",
        "format-ru": "RU"
    },

    "pulseaudio": {
        "format": "{icon}   {volume}%",
        "format-muted": "󰝟",
        "format-icons": {
            "default": ["", "", ""]
        },
        "on-click": "pavucontrol"
    },

    "custom/power": {
        "format": "⏻",
        "on-click": "wlogout",
        "tooltip": false
    }
}
